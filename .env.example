# Backend (.env in backend/ directory — uv runs from there)
# Copy to backend/.env and fill in.

# Set MICAR_POSTGRES_PORT before `docker compose up` to override the default port.
DATABASE_URL=postgresql+psycopg://micar:micar@localhost:5433/micar
MICAR_POSTGRES_PORT=5433

# JWT bridge with the Next.js frontend. Must match frontend/.env.local.
# Generate with: openssl rand -base64 32
JWT_SHARED_SECRET=
JWT_ISSUER=micar-frontend
JWT_AUDIENCE=micar-backend

# Comma-separated list of email addresses permitted to sign in.
# An empty list denies access unless the explicit local dev switch is enabled.
USER_EMAIL_ALLOWLIST=
ALLOW_UNRESTRICTED_DEV_AUTH=false

# Anthropic. Sonnet 4.6 is the default workhorse; Opus 4.7 for clause synthesis
# on regulatory-critical templates; Haiku 4.5 for high-volume reg-feed triage.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL_DEFAULT=claude-sonnet-4-6
LLM_MODEL_SYNTHESIS=claude-opus-4-7
LLM_MODEL_TRIAGE=claude-haiku-4-5

# BRAO posture. API keys alone do not enable outbound processing.
# Enable only after the required processing approval has been documented.
EXTERNAL_LLM_PROCESSING_ENABLED=false
# Set true only where approval expressly permits identifiable mandate facts.
ALLOW_UNREDACTED_EXTERNAL_CLIENT_DATA=false
REDACT_CLIENT_IDENTIFIERS_DEFAULT=true
AUDIT_PERSIST_PROMPT_BODIES=false

# API server
API_HOST=0.0.0.0
API_PORT=8090
CORS_ALLOW_ORIGINS=http://localhost:3000

# Artifact storage path (created on first write)
ARTIFACTS_DIR=./artifacts_store

# Reg feed scheduler (Phase 5). Off by default.
REG_FEED_ENABLED=false
REG_FEED_POLL_INTERVAL_MINUTES=60
