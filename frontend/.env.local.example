# Auth.js
AUTH_SECRET="run: openssl rand -base64 32"
NEXTAUTH_URL=http://localhost:3000

# Dev sign-in (local development only). Disable in production.
DEV_AUTH=true

# Resend magic-link (production path). Requires a database adapter — wired in v2.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="MiCAR Co-Pilot <noreply@your-domain.tld>"

# Backend bridge
BACKEND_URL=http://localhost:8090
# Generate a secret and use the exact same value in backend/.env.
JWT_SHARED_SECRET=""
JWT_ISSUER=micar-frontend
JWT_AUDIENCE=micar-backend
